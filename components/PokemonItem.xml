<?xml version="1.0" encoding="utf-8" ?>

<component name="PokemonItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="showContent"/>
    </interface>

    <children>
        <Poster
            id="pokemonPoster"
            width="200"
            height="200" />
        <Label
            id="pokemonLabel"
            width="150"
            horizAlign="center"
            color="0xFFFFFFFF" 
            height="20"
            translation="[0, 205]" />
    </children>
</component>
