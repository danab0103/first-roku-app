<component name="BaseItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onItemContentChanged"/>
        <field id="focusPercent" type="float" onChange="onFocusStateChanged"/>
        <field id="rowListHasFocus" type="boolean" onChange="onFocusStateChanged"/>
    </interface>

    <children>
        <Poster
            id="focusPoster"
            uri="pkg:/images/rounded_mask_$$RES$$.png"
            blendColor="#301e01"
            width="312"
            height="312"
            visible="false" />

        <MaskGroup 
            id="maskGroup" 
            translation="[6, 6]"
            maskUri="pkg:/images/rounded_mask_$$RES$$.png" >

            <Poster
                id="poster"
                width="300"
                height="300"
                loadDisplayMode="scaleToFill" />
        </MaskGroup>
    </children>
</component>
