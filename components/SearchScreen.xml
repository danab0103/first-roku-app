<?xml version="1.0" encoding="utf-8" ?>
<component name="SearchScreen" initialFocus="openKeyboardButton" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onItemContentChanged"/>
    </interface>
    <children>
        <Rectangle
            id="background"
            color="0x1E1E2F"
            width="1280"
            height="720" />

        <DynamicMiniKeyboard
            id="miniKeyboard"
            translation="[40, 100]" />

        <Button
            id="openKeyboardButton"
            text="Open Keyboard"
            maxWidth="280" 
            height="60"
            translation="[100, 600]" />
        <MarkupGrid
            id="pokemonsGrid"
            translation="[550, 100]"
            itemSize="[200,220]"
            itemSpacing="[10, 14]"
            numColumns="3"
            numRows="2"
            itemComponentName="PokemonItem" />
    </children>

    <script type="text/brightscript" uri="pkg:/components/SearchScreen.brs" />
    <script type="text/brightscript" uri="pkg:/components/NavigationHelper.brs" />
</component>
