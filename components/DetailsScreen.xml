<?xml version="1.0" encoding="utf-8" ?>
<component name="DetailsScreen" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="showDetails" />
    </interface>

    <children>
        <Poster
            id="backgroundPoster"
            width="1280"
            height="720" />

        <Label 
            id="descriptionLabel"
            width="1200"
            horizAlign="center"
            translation="[40,500]"
            wrap="true"/>

        <Button
            id="playVideoButton"
            focusable="false"
            translation = "[0,0]" />

        <Timer
            id="timer"
            repeat="true"
            control="start"
            duration="1"/>
    </children>

    <script type="text/brightscript" uri="pkg:/components/DetailsScreen.brs" />
    <script type="text/brightscript" uri="pkg:/components/NavigationHelper.brs" />
</component>
