<?xml version="1.0" encoding="utf-8" ?>
<component name="VideoScreen" initialFocus="videoId" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="showVideo" />
        <field id="back" type="boolean" value="false" />
    </interface>

    <children>
        <Video
            id="videoId"
            width="1280"
            height="720" />
    </children>

    <script type="text/brightscript" uri="pkg:/components/VideoScreen.brs" />
</component>
