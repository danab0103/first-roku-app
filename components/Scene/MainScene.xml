<?xml version="1.0" encoding="utf-8" ?>

<component name="HelloWorld" extends="Scene"> 
	<children>
      <Poster 
        id="background" 
        uri="pkg:/images/cat-bg.jpg" 
        width="1280" 
        height="720" 
        opacity="1.0" />
        
      <Label
        id="titleLabel"
        text=""
        color="#ffffff" 
        translation="[0,300]" />

      <LayoutGroup
        id="buttonGroup"
        layoutDirection="horiz"
        itemSpacings="[20]"
