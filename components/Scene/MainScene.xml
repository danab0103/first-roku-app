<component name="MainScreen" extends="Scene"> 
    <interface>
        <field id="argsContent" type="assocArray" onChange="onArgsContentChanged" />
        <field id="lastFocusedChild" type="node" />
    </interface>

    <children>
        <Poster 
            id="background" 
            uri="pkg:/images/cat-bg.jpg" 
            width="1280" 
            height="720" 
            opacity="1.0" />
          
        <Label
            id="titleLabel"
            text=""
            color="#ffffff" 
            translation="[600,20]" />

        <LayoutGroup
            id="buttonGroup"
            layoutDirection="horiz"
            itemSpacings="[20]"
            translation="[200,400]">

            <CustomButton
                id="playVideoButton" 
                width="180"
                height="44"
                text="Play Video" />
                
            <CustomButton
                id="searchButton"
                width="180"
                height="44"
                text="Search Pokemon"
                visible="false" />
        </LayoutGroup>

        <RowList
            id="imageList"
            translation="[200,500]"
            numRows="1"
            itemComponentName="BaseItem"
            itemSize="[952,0]"
            rowHeights="[208]"
            rowItemSize="[[208, 208]]"
            rowItemSpacing="[[30, 0]]"
            rowFocusAnimationStyle="fixedFocusWrap" 
            drawFocusFeedback="false" />
    </children>
</component>
