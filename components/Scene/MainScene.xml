<component name="HelloWorld" extends="Scene"> 
    <interface>
        <field id="argsContent" type="assocArray" onChange="onArgsContentChanged" />
    </interface>

    <children>
        <Poster 
            id="background" 
            uri="pkg:/images/cat-bg.jpg" 
            width="1280" 
            height="720" 
            opacity="1.0" />
          
        <Label
            id="titleLabel"
            text=""
            color="#ffffff" 
            translation="[600,20]" />

        <LayoutGroup
            id="buttonGroup"
            layoutDirection="horiz"
            itemSpacings="[20]"
            translation="[220,400]">

            <Button
                id="playVideoButton"
                text="Play Video" 
                showFocusFootprint="true"
                focusFootprintBitmapUri="pkg:/images/not_focused.png" 
                focusBitmapUri="pkg:/images/focused.png"
                iconUri=""
                minWidth="10"
                height="54"
                focusedIconUri="" />
                
            <Button
                id="searchButton"
                text="Search"
                showFocusFootprint="true"
                focusFootprintBitmapUri="pkg:/images/not_focused.png" 
                focusBitmapUri="pkg:/images/focused.png"
                iconUri=""
                minWidth="10"
                height="54"
                focusedIconUri=""
                visible="false" />
        </LayoutGroup>

        <RowList
            id="imageList"
            translation="[200,500]"
            numRows="1"
            itemComponentName="BaseItem"
            itemSize="[920,0]"
            rowHeights="[200]"
            rowItemSize="[[200, 200]]"
            rowItemSpacing="[[30, 0]]"
            rowFocusAnimationStyle="fixedFocusWrap" />
    </children>
</component>
