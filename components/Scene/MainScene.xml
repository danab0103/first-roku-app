<component name="MainScreen" extends="Scene"> 
    <interface>
        <field id="argsContent" type="assocArray" onChange="onArgsContentChanged" />
        <field id="lastFocusedChild" type="node" />
    </interface>

    <customization suspendhandler="onCustomSuspend" />
    <customization resumehandler="onCustomResume" />

    <children>
        <Poster 
            id="background" 
            uri="pkg:/images/cat-bg.jpg" 
            width="1280" 
            height="720" 
            opacity="1.0" />
          
        <Label
            id="titleLabel"
            text=""
            color="#ffffff" 
            translation="[600,20]" />

        <LayoutGroup
            id="mainGroup"
            layoutDirection="vert"
            horizAlignment="custom"
            itemSpacings="[60]"
            translation="[200,450]">

            <LayoutGroup
                id="buttonGroup"
                translation="[-100, 0]"
                layoutDirection="horiz"
                itemSpacings="[20]">

                <CustomButton
                    id="playVideoButton" 
                    width="180"
                    height="44"
                    text="Play Video" />

                <CustomButton
                    id="toPokeballsButton"
                    width="180"
                    height="44"
                    text="To Pokeballs" />

                <CustomButton
                    id="getRandomDogButton"
                    width="180"
                    height="44"
                    text="Get Random Dog" />
                    
                <CustomButton
                    id="searchButton"
                    width="180"
                    height="44"
                    text="Search Pokemon"
                    visible="false" />
            </LayoutGroup>

            <RowList
                id="imageList"
                numRows="1"
                opacity="0.2"
                itemComponentName="BaseItem"
                itemSize="[952,0]"
                rowHeights="[208]"
                rowItemSize="[[208, 208]]"
                rowItemSpacing="[[30, 0]]"
                rowFocusAnimationStyle="fixedFocusWrap" 
                drawFocusFeedback="false"/>
        </LayoutGroup>
    </children>
</component>
