<component name="MainScreen" extends="Scene"> 
    <interface>
        <field id="argsContent" type="assocArray" onChange="onArgsContentChanged" />
        <field id="lastFocusedChild" type="node" />
    </interface>

    <customization suspendhandler="onCustomSuspend" />
    <customization resumehandler="onCustomResume" />

    <children>
        <Poster 
            id="background" 
            uri="pkg:/images/cat-bg.jpg" 
            width="1920" 
            height="1080" />
          
        <Label
            id="titleLabel"
            text=""
            color="#ffffff" 
            translation="[900,30]" />

        <LayoutGroup
            id="mainGroup"
            layoutDirection="vert"
            horizAlignment="custom"
            itemSpacings="[90]"
            translation="[300,675]">

            <LayoutGroup
                id="buttonGroup"
                translation="[-150, 0]"
                layoutDirection="horiz"
                itemSpacings="[30]">

                <CustomButton
                    id="playVideoButton" 
                    width="270"
                    height="66"
                    text="Play Video" />

                <CustomButton
                    id="toPokeballsButton"
                    width="270"
                    height="66"
                    text="To Pokeballs" />

                <CustomButton
                    id="getRandomDogButton"
                    width="270"
                    height="66"
                    text="Get Random Dog" />
                    
                <CustomButton
                    id="searchButton"
                    width="270"
                    height="66"
                    text="Search Pokemon"
                    visible="false" />
            </LayoutGroup>

            <RowList
                id="imageList"
                numRows="1"
                opacity="0.2"
                itemComponentName="BaseItem"
                itemSize="[1428,0]"
                rowHeights="[312]"
                rowItemSize="[[312, 312]]"
                rowItemSpacing="[[45, 0]]"
                rowFocusAnimationStyle="fixedFocusWrap" 
                drawFocusFeedback="false"/>
        </LayoutGroup>
    </children>
</component>
