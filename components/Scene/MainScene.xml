<component name="MainScreen" extends="Scene"> 
    <interface>
        <field id="argsContent" type="assocArray" onChange="onArgsContentChanged" />
        <field id="lastFocusedChild" type="node" />
    </interface>

    <children>
        <Poster 
            id="background" 
            uri="pkg:/images/cat-bg.jpg" 
            width="1280" 
            height="720" 
            opacity="1.0" />
          
        <Label
            id="titleLabel"
            text=""
            color="#ffffff" 
            translation="[600,20]" />

        <LayoutGroup
            id="mainGroup"
            layoutDirection="vert"
            horizAlignment="custom"
            itemSpacings="[60]"
            translation="[200,450]">

            <LayoutGroup
                id="buttonGroup"
                layoutDirection="horiz"
                itemSpacings="[20]">

                <CustomButton
                    id="playVideoButton" 
                    width="180"
                    height="44"
                    text="Play Video" />
                    
                <CustomButton
                    id="searchButton"
                    width="180"
                    height="44"
                    text="Search Pokemon"
                    visible="false" />
            </LayoutGroup>

            <RowList
                id="imageList"
                numRows="1"
                opacity="0.2"
                itemComponentName="BaseItem"
                itemSize="[952,0]"
                rowHeights="[208]"
                rowItemSize="[[208, 208]]"
                rowItemSpacing="[[30, 0]]"
                rowFocusAnimationStyle="fixedFocusWrap" 
                drawFocusFeedback="false"/>
        </LayoutGroup>

        <Animation
            id="mainGroupAnimation"
            duration="1"
            easeFunction="inOutQuad">

            <Vector2DFieldInterpolator id="mainGroupAnimationVector"
                key="[0, 1]"
                keyValue="[[200, 450], [200, 350]]"
                fieldToInterp="mainGroup.translation" />

            <FloatFieldInterpolator id="mainGroupAnimationFloat"
                key="[0, 1]"
                keyValue="[0.2, 1]"
                fieldToInterp="imageList.opacity" />
        </Animation>
    </children>
</component>
