<component name="SearchScreen" initialFocus="miniKeyboard" extends="BaseScreen">
    <children>
        <Rectangle
            id="background"
            color="0x1E1E2F"
            width="1280"
            height="720" />

        <LayoutGroup
                id="screenGroup"
                layoutDirection="horiz"
                horizAlignment="center"
                itemSpacings="[20]"
                translation="[650, 100]" >

            <LayoutGroup
                id="keyboardGroup"
                layoutDirection="vert"
                horizAlignment="center"
                itemSpacings="[20]" >

                <DynamicMiniKeyboard
                    id="miniKeyboard" />
                
                <CustomButton
                    id="openKeyboardButton"
                    width="180"
                    height="44" 
                    text="Open Keyboard" />
            </LayoutGroup>

            <MarkupGrid
                id="pokemonsGrid"
                itemSize="[200,220]"
                itemSpacing="[30, 30]"
                numColumns="3"
                numRows="2"
                wrapDividerBitmapUri=""
                wrapDividerHeight="0"
                itemComponentName="PokemonItem" 
                drawFocusFeedback="false" />
        </LayoutGroup>
    </children>
</component>
