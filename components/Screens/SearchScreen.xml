<component name="SearchScreen" initialFocus="miniKeyboard" extends="BaseScreen">
    <children>
        <Rectangle
            id="background"
            color="0x1E1E2F"
            width="1920"
            height="1080" />

        <LayoutGroup
                id="screenGroup"
                layoutDirection="horiz"
                horizAlignment="center"
                itemSpacings="[30]"
                translation="[975, 150]" >

            <LayoutGroup
                id="keyboardGroup"
                layoutDirection="vert"
                horizAlignment="center"
                itemSpacings="[30]" >

                <DynamicMiniKeyboard
                    id="miniKeyboard" />
                
                <CustomButton
                    id="openKeyboardButton"
                    width="270"
                    height="66" 
                    text="Open Keyboard" />
            </LayoutGroup>

            <MarkupGrid
                id="pokemonsGrid"
                itemSize="[300,330]"
                itemSpacing="[45, 45]"
                numColumns="3"
                numRows="2"
                wrapDividerBitmapUri=""
                wrapDividerHeight="0"
                itemComponentName="PokemonItem" 
                drawFocusFeedback="false" />
        </LayoutGroup>
    </children>
</component>
