<component name="SearchScreen" initialFocus="openKeyboardButton" extends="BaseScreen">
    <children>
        <Rectangle
            id="background"
            color="0x1E1E2F"
            width="1280"
            height="720" />

        <LayoutGroup
                id="screenGroup"
                layoutDirection="horiz"
                horizAlignment="center"
                itemSpacings="[20]"
                translation="[650, 100]" >

            <LayoutGroup
                id="keyboardGroup"
                layoutDirection="vert"
                horizAlignment="center"
                itemSpacings="[20]" >

                <DynamicMiniKeyboard
                    id="miniKeyboard" />
                
                <Button
                    id="openKeyboardButton"
                    text="Open Keyboard"
                    showFocusFootprint="true"
                    focusFootprintBitmapUri="pkg:/images/not_focused.png" 
                    focusBitmapUri="pkg:/images/focused.png"
                    iconUri=""
                    minWidth="10"
                    height="54"
                    focusedIconUri="" />
            </LayoutGroup>

            <MarkupGrid
                id="pokemonsGrid"
                translation="[550, 100]"
                itemSize="[200,225]"
                itemSpacing="[10, 10]"
                numColumns="3"
                numRows="2"
                wrapDividerBitmapUri=""
                wrapDividerHeight="0"
                itemComponentName="PokemonItem" />
        </LayoutGroup>
    </children>
</component>
