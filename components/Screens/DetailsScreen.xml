<component name="DetailsScreen" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="showDetails" />
    </interface>

    <children>
        <Poster
            id="backgroundPoster"
            width="1280"
            height="720" />

        <Label 
            id="descriptionLabel"
            width="1200"
            horizAlign="center"
            translation="[40,500]"
            wrap="true"/>

        <Button
            id="playVideoButton"
            translation="[490, 10]" />

        <Timer
            id="timer"
            repeat="true"
            control="start"
            duration="1"/>
    </children>
</component>
