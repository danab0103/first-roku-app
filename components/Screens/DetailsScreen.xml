<component name="DetailsScreen" extends="BaseScreen">
    <children>
        <Poster
            id="backgroundPoster"
            width="1920"
            height="1080" />

        <CustomButton
            id="playVideoButton"
            translation="[21, 720]"
            height="66"
            visible="false"/>

        <Rectangle 
            id="descriptionBackground"
            width="1920"
            translation="[0,825]"
            visible="false"
            color="0xFFFFFFFF" />

        <Label 
            id="descriptionLabel"
            width="1800"
            visible="false"
            color="0x000000FF"
            horizAlign="center"
            translation="[60,825]"
            wrap="true"/>

        <Timer
            id="timer"
            repeat="true"
            control="stop"
            duration="1"/>
    </children>
</component>
